{
  "appId": "com.custerm.app",
  "productName": "Custerm",
  "directories": {
    "output": "release"
  },
  "npmRebuild": false,
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "icon/**/*",
    "node_modules/**/*",
    "!node_modules/**/*.{md,map,ts}",
    "!node_modules/**/test/**",
    "!node_modules/**/docs/**",
    "!node_modules/**/.github/**"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "icon/custerm.ico",
    "artifactName": "${productName}-Setup-${version}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Custerm",
    "installerIcon": "icon/custerm.ico",
    "uninstallerIcon": "icon/custerm.ico",
    "installerHeaderIcon": "icon/custerm.ico",
    "deleteAppDataOnUninstall": false
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "icon": "icon/custerm.icns",
    "category": "public.app-category.developer-tools",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "identity": null,
    "extendInfo": {
      "NSHighResolutionCapable": true
    }
  },
  "dmg": {
    "artifactName": "${productName}-${version}-arm64.${ext}"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "TerminalEmulator",
    "icon": "icon/custerm_512.png"
  }
}
