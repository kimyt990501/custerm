{
  "appId": "com.custerm.app",
  "productName": "Custerm",
  "directories": {
    "output": "release"
  },
  "npmRebuild": false,
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "icon/**/*",
    "node_modules/**/*",
    "!node_modules/**/*.{md,map,ts}",
    "!node_modules/**/test/**",
    "!node_modules/**/docs/**",
    "!node_modules/**/.github/**"
  ],
  "win": {
    "target": [
      {
        "target": "dir",
        "arch": ["x64"]
      }
    ],
    "icon": "icon/custerm.ico",
    "signAndEditExecutable": false
  },
  "mac": {
    "target": ["dmg"],
    "icon": "icon/custerm.icns"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "TerminalEmulator",
    "icon": "icon/custerm_512.png"
  }
}
